enum FriendshipStatus {
  PENDING    // Nhận được lời mời (chưa phản hồi)
  REQUESTED  // Đã gửi lời mời (chờ đối phương)
  ACCEPTED   // Đã là bạn bè
  BLOCKED    // Đã chặn
}

model Friendship {
  id       String           @id @default(uuid())
  userId   String
  friendId String
  status   FriendshipStatus

  user   User @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOfUser", fields: [friendId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, friendId]) // 1 user chỉ có 1 relationship với 1 friend
  @@index([userId, status])    // Query: "tất cả bạn bè accepted của user X"
  @@index([friendId])
}