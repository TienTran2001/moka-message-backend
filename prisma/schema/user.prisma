model User {
  id             String   @id @default(uuid())
  username       String   @unique
  displayName    String
  email          String   @unique
  hashedPassword String
  avatarUrl      String?
  avatarId       String?
  bio            String?
  phone          String?

  // Friendships
  friendships   Friendship[] @relation("UserFriendships")  // relationships mà user sở hữu
  friendOf      Friendship[] @relation("FriendOfUser")    // relationships mà user là bạn bè

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions Session[]

  @@index([email])
  @@index([username])
}
